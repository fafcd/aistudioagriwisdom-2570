    {
      id: `b${activeBranch}_q1_3_perseverance`,
      text: (activeBranch === 1 || activeBranch === 3 || activeBranch === 2 || activeBranch === 4)
        ? "1.3 มีคุณธรรม จริยธรรม และความเสียสละ"
