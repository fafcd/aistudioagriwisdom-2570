import React, { useState, useEffect } from "react";
import { Candidate, Evaluation } from "../types";
import { Award, AlertTriangle, ArrowLeft, ArrowRight, Save, ListCollapse, TableProperties } from "lucide-react";
import { motion, AnimatePresence } from "motion/react";

interface EvaluationFormProps {
  candidates: Candidate[];
  activeBranch: 1 | 2 | 3 | 4;
  candidateId: string;
  committeeName: string;
  committeeAgency: string;
  onSuccess: () => void;
  onCancel: () => void;
}

interface Question {
  id: string; // matches the Google Sheets header exact field name
  text: string;
  maxScore: number;
  desc: string;
}

export default function EvaluationForm({
  candidates,
  activeBranch,
  candidateId,
  committeeName,
  committeeAgency,
  onSuccess,
  onCancel
}: EvaluationFormProps) {
  const candidate = candidates.find(c => c.id === candidateId);
  const [currentStep, setCurrentStep] = useState(1);
  const [scores, setScores] = useState<Record<string, number>>({});
  const [comments, setComments] = useState("");
  const [error, setError] = useState("");
  const [isSubmitting, setIsSubmitting] = useState(false);
  const [showMappingHelp, setShowMappingHelp] = useState(false);

  // Helper for Branch 1 Questions
  const getBranch1Questions = (): Question[] => [
    // --- ส่วนที่ 1: คุณลักษณะส่วนบุคคล (30 คะแนน) ---
    // 1.1 เป็นผู้สร้างสรรค์องค์ความรู้และมีคุญูปการด้านการเกษตร (10 คะแนน)
    {
      id: "b1_q1_1_1",
      text: "1. เป็นบุคคลที่มีคุณูปการต่อภาคเกษตร มีชื่อเสียงได้รับการยอมรับในระดับพื้นที่หรือกลุ่มอาชีพ ไม่น้อยกว่า 20 ปี  (คะแนนเต็ม 4 คะแนน)",
      maxScore: 4,
      desc: ""
    },
    {
      id: "b1_q1_1_2",
      text: "2. เป็นบุคคลที่มีคุณูปการต่อภาคเกษตร มีชื่อเสียงได้รับการยอมรับในระดับประเทศ ไม่น้อยกว่า 20 ปี  (คะแนนเต็ม 4 คะแนน)",
      maxScore: 4,
      desc: ""
    },
    {
      id: "b1_q1_1_3",
      text: "3. เป็นบุคคลที่มีคุณูปการต่อภาคเกษตร มีชื่อเสียงได้รับการยอมรับในระดับต่างประเทศ ไม่น้อยกว่า 10 ปี (คะแนนเต็ม 2 คะแนน)",
      maxScore: 2,
      desc: ""
    },
    // 1.2 การประพฤติตนเป็นแบบอย่างที่ดี ได้ความยอมรับจากสังคม (10 คะแนน)
    {
      id: "b1_q1_2_1",
      text: "1. ขยันหมั่นเพียร ใช้เวลาว่างให้เกิดประโยชน์ เป็นตัวอย่างของการพึ่งพาตนเอง  (คะแนนเต็ม 2 คะแนน)",
      maxScore: 2,
      desc: ""
    },
    {
      id: "b1_q1_2_2",
      text: "2. เป็นแบบอย่างที่ดีของสมาชิกในครอบครัว ผู้คนในระดับชุมชนและประเทศ  (คะแนนเต็ม 2 คะแนน)",
      maxScore: 2,
      desc: ""
    },
    {
      id: "b1_q1_2_3",
      text: "3. มีระเบียบวินัย เคารพกฎหมาย มีมารยาทและรับผิดชอบต่อส่วนรวม  (คะแนนเต็ม 2 คะแนน)",
      maxScore: 2,
      desc: ""
    },
    {
      id: "b1_q1_2_4",
      text: "4. ปฏิบัติตนตามครรลองของระบอบประชาธิปไตย  (คะแนนเต็ม 2 คะแนน)",
      maxScore: 2,
      desc: ""
    },
    {
      id: "b1_q1_2_5",
      text: "5. เป็นผู้ใฝ่รู้และนำความรู้มาปฏิบัติงานจนเกิดประโยชน์ (คะแนนเต็ม 2 คะแนน)",
      maxScore: 2,
      desc: ""
    },
    // 1.3 มีคุณธรรม จริยธรรม และความเสียสละ (10 คะแนน)
    {
      id: "b1_q1_3_1",
      text: "1. มีนิสัยเอื้อเฟื้อเผื่อแผ่ ช่วยเหลือผู้อื่นโดยไม่หวังสิ่งตอบแทน  (คะแนนเต็ม 5 คะแนน)",
      maxScore: 5,
      desc: ""
    },
    {
      id: "b1_q1_3_2",
      text: "2. ยึดถือและปฏิบัติตามหลักคุณธรรมทางศาสนา (คะแนนเต็ม 5 คะแนน)",
      maxScore: 5,
      desc: ""
    },

    // --- ส่วนที่ 2: ผลงานที่สร้างคุณประโยชน์ (40 คะแนน) ---
    // 2.1 มีผลงานเป็นที่ประจักษ์ และได้รับการยอมรับ (10 คะแนน)
    {
      id: "b1_q2_1_1",
      text: "1. ได้รับรางวัลและประกาศเกียรติคุณในระดับประเทศและหรือในระดับนานาชาติ  (คะแนนเต็ม 3 คะแนน)",
      maxScore: 3,
      desc: ""
    },
    {
      id: "b1_q2_1_2",
      text: "2. ผลงานได้รับการตีพิมพ์และเผยแพร่ผ่านสื่อต่างๆ อย่างกว้างขวางในระดับประเทศ และหรือได้รับเชิญเป็นวิทยากรเพื่อบรรยายและนำเสนอผลงานในระดับประเทศ  (คะแนนเต็ม 3 คะแนน)",
      maxScore: 3,
      desc: ""
    },
    {
      id: "b1_q2_1_3",
      text: "3. ร่วมเป็นคณะกรรมการหรือแกนนำองค์กรที่มีบทบาทในการกำหนดนโยบายและผลักดันขับเคลื่อนการพัฒนาภาคการเกษตร (คะแนนเต็ม 4 คะแนน)",
      maxScore: 4,
      desc: ""
    },
    // 2.2 ประโยชน์ของผลงานที่เกี่ยวข้องกับเศรษฐกิจและสังคมภาคการเกษตร (10 คะแนน)
    {
      id: "b1_q2_2_1",
      text: "1. ผลงานก่อให้เกิดการเปลี่ยนแปลงรูปแบบการผลิตภาคการเกษตรในระดับชุมชนท้องถิ่น นำสู่การพัฒนาคุณภาพชีวิตและความเป็นอยู่ที่ดีขึ้น  (คะแนนเต็ม 3 คะแนน)",
      maxScore: 3,
      desc: ""
    },
    {
      id: "b1_q2_2_2",
      text: "2. ผลงานก่อให้เกิดการเปลี่ยนแปลงโครงสร้าง การผลิตด้านการเกษตรที่มีผลต่อการกระจายรายได้ที่เป็นธรรมและทั่วถึง  (คะแนนเต็ม 3 คะแนน)",
      maxScore: 3,
      desc: ""
    },
    {
      id: "b1_q2_2_3",
      text: "3. ผลงานก่อให้เกิดการขยายตัวของการผลิตทางการเกษตรส่งผลต่อการสร้างรายได้และการเจริญเติบโตทางเศรษฐกิจ (คะแนนเต็ม 4 คะแนน)",
      maxScore: 4,
      desc: ""
    },
    // 2.3 การนำผลงานไปใช้ประโยชน์ในการแก้ไขปัญหา (10 คะแนน)
    {
      id: "b1_q2_3_1",
      text: "1. สามารถแก้ไขปัญหาที่เกิดขึ้นกับเกษตรกรได้ในเฉพาะปัญหาและในระดับพื้นที่  (คะแนนเต็ม 3 คะแนน)",
      maxScore: 3,
      desc: ""
    },
    {
      id: "b1_q2_3_2",
      text: "2. ได้รับการจำลองรูปแบบและผลงานเพื่อนำไปใช้แก้ไขปัญหาในหลากหลายพื้นที่  (คะแนนเต็ม 3 คะแนน)",
